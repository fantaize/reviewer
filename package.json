{
  "name": "ai-code-reviewer",
  "version": "1.0.0",
  "description": "Multi-agent AI code review bot for GitHub PRs, powered by Claude",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "tsx watch src/index.ts",
    "smee": "smee -u https://smee.io/zKRa4sekdvLn24d -t http://localhost:3000/webhook",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@octokit/auth-app": "^7.1.0",
    "@octokit/rest": "^21.1.0",
    "@octokit/webhooks": "^13.4.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "parse-diff": "^0.11.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "smee-client": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
