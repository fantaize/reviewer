GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
PORT=3000
CONFIDENCE_THRESHOLD=80

# Model settings
MODEL=claude-sonnet-4-6
VERIFIER_MODEL=claude-opus-4-6
EFFORT=high

# Allow /review comment command to trigger manual reviews (default: false)
ALLOW_MANUAL_REVIEW=false

# Optional: Anthropic API key (overrides Claude Code subscription auth)
ANTHROPIC_API_KEY=
